{
  "name": "peer-calls",
  "version": "4.0.0",
  "private": true,
  "description": "VidyaX - Secure peer-to-peer video conferencing solution.",
  "repository": "https://github.com/peer-calls/peer-calls",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "peer-calls": "./lib/index.js"
  },
  "scripts": {
    "start": "npm run build && cross-env PEERCALLS_FS=. PEERCALLS_NETWORK_TYPE=sfu go run main.go",
    "start:mesh": "npm run build && cross-env PEERCALLS_FS=. go run main.go",
    "start:sfu": "npm run build && cross-env PEERCALLS_FS=. PEERCALLS_NETWORK_TYPE=sfu go run main.go",
    "dev": "concurrently --kill-others \"npm run js:watch\" \"npm run css:watch\" \"npm run start\"",
    "dev:mesh": "concurrently --kill-others \"npm run js:watch\" \"npm run css:watch\" \"npm run start:mesh\"",
    "start:watch": "chastifol [ npm run js:watch ] [ npm run css:watch ] [ npm run start ]",
    "prepublishOnly": "npm run build",
    "build": "npm run css && npm run js",
    "build:go:linux": "make build-linux",
    "build:go": "make build",
    "test": "jest",
    "test:go": "go test ./...",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "js": "webpack --config webpack.prod.js --optimization-minimize",
    "js:watch": "webpack --config webpack.dev.js --watch",
    "css": "sass ./src/sass/style.sass ./build/style.css",
    "css:watch": "npm run css && sass --watch ./src/sass/style.sass ./build/style.css",
    "lint": "eslint --ext ts,tsx .",
    "lint:fix": "eslint --ext ts,tsx --fix .",
    "ci": "npm run lint && npm run test:coverage && npm run ts && npm run build",
    "ts:watch": "tsc --build . --watch --preserveWatchOutput",
    "ts": "tsc --build .",
    "clean": "rimraf lib/ tsconfig.tsbuildinfo build/*"
  },
  "author": "Jerko Steiner",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/classnames": "^2.3.0",
    "@types/debug": "^4.1.13",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^26.0.24",
    "@types/lodash": "^4.17.24",
    "@types/node": "^14.18.63",
    "@types/react": "^17.0.91",
    "@types/react-dom": "^17.0.26",
    "@types/react-redux": "^7.1.34",
    "@types/react-transition-group": "^4.4.12",
    "@types/redux-logger": "^3.0.13",
    "@types/simple-peer": "^9.11.9",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "babel-loader": "^8.4.1",
    "buffer": "^6.0.3",
    "chastifol": "^4.1.0",
    "classnames": "^2.5.1",
    "concurrently": "^9.2.1",
    "core-js": "^3.49.0",
    "cross-env": "^10.1.0",
    "debug": "^4.4.3",
    "eslint": "^7.32.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "fastestsmallesttextencoderdecoder": "^1.0.22",
    "jest": "^30.3.0",
    "lodash": "^4.17.23",
    "process": "^0.11.10",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-icons": "^3.11.0",
    "react-redux": "^7.2.9",
    "react-transition-group": "^4.4.5",
    "redux": "^4.2.1",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^2.4.2",
    "regenerator-runtime": "^0.13.11",
    "reselect": "^4.1.8",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^3.0.2",
    "sass": "^1.98.0",
    "screenfull": "^5.2.0",
    "simple-peer": "git+https://github.com/jeremija/simple-peer.git#expose-transceiver-sender-receiver",
    "ts-jest": "^29.4.6",
    "typescript": "^4.9.5",
    "webpack": "^5.105.4",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^4.10.0",
    "webrtc-adapter": "^7.7.1",
    "worker-loader": "^3.0.8"
  }
}
